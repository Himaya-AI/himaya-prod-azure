# DLP Gateway — local development defaults
DLP_ENV=local
LOG_LEVEL=INFO

SMTP_HOST=0.0.0.0
SMTP_PORT=2525
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

SPOOL_DIR=/var/dlp/spool
DATA_DIR=/var/dlp/data
QUEUE_DIR=/var/dlp/queues
TENANT_CONFIG_PATH=/app/conf/tenants/local-tenant.json

# Local mode: publish allow command automatically after capture
FORCE_ALLOW=true

# Azurite Blob
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
BLOB_CONTAINER=dlp-mime

# Fake provider return path (MailHog)
RELAY_HOST=mailhog
RELAY_PORT=1025
RELAY_USE_TLS=false

MAX_MESSAGE_BYTES=26214400
MAX_RECIPIENTS=100
