<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <theme><name>Clearlooks</name></theme>
  <applications>
    <application class="Firefox">
      <maximized>yes</maximized>
    </application>
    <application class="Thunar">
      <decor>yes</decor>
    </application>
    <application class="libreoffice">
      <decor>yes</decor>
    </application>
  </applications>
  <keyboard>
    <keybind key="C-q"><action name="Exit"/></keybind>
    <keybind key="super-e">
      <action name="Execute"><command>thunar /root/Downloads</command></action>
    </keybind>
    <keybind key="super-t">
      <action name="Execute"><command>xterm -fa 'Monospace' -fs 12 -bg black -fg green</command></action>
    </keybind>
  </keyboard>
  <menu>
    <file>/root/.config/openbox/menu.xml</file>
    <showIcons>yes</showIcons>
    <mouseDelay>200</mouseDelay>
  </menu>
  <mouse>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
    </context>
  </mouse>
</openbox_config>
