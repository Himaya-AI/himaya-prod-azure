REPUTATION_SERVICE_NAME=helios-reputation-service
REPUTATION_ENV=local
REPUTATION_LOG_LEVEL=INFO

# Redis / ElastiCache (also used for Helios IOC feed sets: ioc_urlhaus:entries, etc.)
REDIS_URL=redis://localhost:6379
REPUTATION_CACHE_TTL_SECONDS=259200
REPUTATION_ERROR_TTL_SECONDS=900

# Threat intel source API keys
VIRUSTOTAL_API_KEY=
ALIENVAULT_OTX_API_KEY=
URLSCAN_API_KEY=
ABUSECH_API_KEY=

# Optional API protection for cache admin endpoints.
# Leave empty for local development only.
REPUTATION_ADMIN_API_KEY=
