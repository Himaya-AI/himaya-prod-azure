# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_dev_password@localhost:5432/sentinel_mail

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Neo4j (optional — system runs in mock mode without it) ───────────────────
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_dev_password

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-secret-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # Required for threat classification + auto-triage

# ─── Threat Intelligence ──────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=                 # Optional — URL/domain reputation (free tier: 4 req/min)
HIBP_API_KEY=                       # Optional — Have I Been Pwned
WHOISXML_API_KEY=                   # Optional — Domain WHOIS/age lookups

# ─── Azure (primary) ──────────────────────────────────────────────────────────
AZURE_REGION=uaenorth
AZURE_STORAGE_ACCOUNT=himayaprodsa
AZURE_SERVICE_BUS_NAMESPACE=himaya-prod-bus
AZURE_CLIENT_ID=                       # Managed identity client ID for Container Apps
AZURE_COMMUNICATION_CONNECTION_STRING=  # Optional — only if using Azure Email instead of SES

# ─── AWS (fallback — SES still uses us-east-1) ───────────────────────────────
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=                # Not needed if running on ECS with task role
# AWS_SECRET_ACCESS_KEY=            # Not needed if running on ECS with task role
# AWS_SQS_EMAIL_QUEUE_URL=           # Optional SQS fallback

# ─── Google Workspace (DWD — required for physical quarantine of Gmail) ───────
# Base64-encoded service account JSON key
# Get from: GCP → IAM → Service Accounts → Keys → Add Key → JSON → base64 -w0
GOOGLE_SERVICE_ACCOUNT_B64=

# ─── Vendor Admin ─────────────────────────────────────────────────────────────
VENDOR_ADMIN_API_KEY=change-me-admin-key   # Protects /api/admin/* endpoints

# ─── DLP / DeepSeek (remains on AWS — accessed via FQDN) ─────────────────────
DEEPSEEK_ENDPOINT=https://your-deepseek-aws-fqdn:8001

# ─── Sandbox (optional — for URL/attachment detonation) ──────────────────────
SANDBOX_ECS_CLUSTER=himaya
SANDBOX_TASK_DEF=helios-sandbox:1
SANDBOX_SUBNET_ID=subnet-xxx
SANDBOX_SG_ID=sg-xxx

# ─── ANVA Threat Feed (optional) ─────────────────────────────────────────────
ANVA_USERNAME=
ANVA_PASSWORD=
